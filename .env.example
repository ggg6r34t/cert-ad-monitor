# ============================================================
# CERT Ad Monitor - Environment Variables
# ============================================================
# Copy this file to .env for use with docker-compose:
#   cp .env.example .env
#
# The .env file is automatically read by docker-compose.
# Do NOT commit .env to version control.
# ============================================================

# Database configuration (SQLite by default)
POSTGRES_URL=postgresql://neondb_owner:

# App secret key (for session management, etc.)
APP_ENCRYPTION_KEY=ky_abcdefghijklmnopqrstuvwxyz0123456789ABCD

# Meta Ad Library API token
# Get yours at: https://www.facebook.com/ads/library/api/
META_AD_LIBRARY_TOKEN=

# Port to expose (default: 3000)
PORT=3000

# Optional internal data directory for persisted clients/triage state
# APP_DATA_DIR=./data

# Production datastore (recommended on Vercel).
# If set, app uses Postgres for state, automation, history, token storage, and scheduler lease.
# POSTGRES_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# 32-byte base64 key used to encrypt server-stored Meta token.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# Automation scheduler (internal worker in Next.js process)
AUTO_SCAN_ENABLED=true
AUTO_SCAN_INTERVAL_MINUTES=30
AUTO_SCAN_MAX_PAGES=3
AUTO_SCAN_MAX_QUERIES=8

# Scan queue controls
SCAN_QUEUE_CONCURRENCY=2
SCAN_QUEUE_MIN_INTERVAL_MS=0

# Meta API circuit breaker
META_CIRCUIT_BREAKER_FAILURES=5
META_CIRCUIT_BREAKER_COOLDOWN_MS=90000

# Internal API protection for automation endpoints
# Required by /api/automation/run and /api/automation/status
INTERNAL_API_KEY=

# Alert routing
# Slack incoming webhook URL
SLACK_WEBHOOK_URL=

# Telegram bot alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
