# ============================================================
# CERT Ad Monitor — Environment Variables
# ============================================================
# Copy this file to .env for use with docker-compose:
#   cp .env.example .env
#
# The .env file is automatically read by docker-compose.
# Do NOT commit .env to version control.
# ============================================================

# Meta Ad Library API token (optional — can also be set in the UI)
# Get yours at: https://www.facebook.com/ads/library/api/
META_AD_LIBRARY_TOKEN=

# Port to expose (default: 3000)
PORT=3000